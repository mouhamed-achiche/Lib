{
  "name": "backend",
  "version": "1.0.0",
  "description": "IBN SINA Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:setup": "node scripts/setup-database.js",
    "db:migrate": "node scripts/migrate-to-postgres.js",
    "db:rollback": "node scripts/rollback-migration.js",
    "db:export": "node scripts/export-sqlite-to-json.js",
    "db:import": "node scripts/import-json-to-postgres.js",
